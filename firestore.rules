rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'elinelson992@gmail.com';
    }

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Projects rules
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Posts rules
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Comments rules
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if false; // Comments cannot be edited once posted
    }
  }
}
